rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Moves collection - allow authenticated users to read/write their own moves
    match /moves/{moveId} {
      allow read, write: if request.auth != null && (
        // Allow if user is the owner (support both old and new field names)
        resource.data.createdBy == request.auth.uid ||
        resource.data.ownerId == request.auth.uid ||
        // Allow if user is a participant
        request.auth.uid in resource.data.participants
      );
      
      // Allow create if user is authenticated
      allow create: if request.auth != null && 
        (request.auth.uid == resource.data.createdBy || 
         request.auth.uid == resource.data.ownerId);
      
      // Boxes subcollection
      match /boxes/{boxId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      // Owners subcollection
      match /owners/{ownerId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      // Calendar events subcollection
      match /calendar_events/{eventId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      // Budget subcollections
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      match /categories/{categoryId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      match /budget/{budgetDoc} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      // Planner subcollections
      match /plannerTasks/{taskId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      match /plannerTimeframes/{timeframeId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
      
      match /plannerConfig/{configId} {
        allow read, write: if request.auth != null && (
          // Check parent move permissions (support both field names)
          get(/databases/$(database)/documents/moves/$(moveId)).data.createdBy == request.auth.uid ||
          get(/databases/$(database)/documents/moves/$(moveId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/moves/$(moveId)).data.participants
        );
      }
    }
    
    // Users collection for user profile data
    match /users/{userId} {
      // Allow users to read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow other authenticated users to read public profile info (for presence display)
      allow read: if request.auth != null;
    }
    
    // Presence collection for real-time user presence
    // Documents are stored as {moveId}_{userId}
    match /presence/{presenceId} {
      // Allow all authenticated users to read and write presence documents
      // This is safe since presence data is not sensitive (just online status)
      allow read, write: if request.auth != null;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}