rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is a participant in a move
    function isMoveParticipant(moveId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/moves/$(moveId)) &&
             get(/databases/$(database)/documents/moves/$(moveId)).data.participants[request.auth.uid] == true;
    }
    
    // Global presence collection rules
    match /presence/{docId} {
      // Allow read if user is authenticated and part of the move
      allow read: if isAuthenticated() && 
                  resource.data.moveId != null &&
                  isMoveParticipant(resource.data.moveId);
      
      // Allow create/update only if user is updating their own presence and is part of the move
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.moveId != null &&
                    isMoveParticipant(request.resource.data.moveId) &&
                    request.resource.data.keys().hasAll(['userId', 'online', 'lastSeen', 'moveId']);
                    
      allow update: if isAuthenticated() &&
                    request.auth.uid == resource.data.userId &&
                    resource.data.moveId != null &&
                    isMoveParticipant(resource.data.moveId) &&
                    request.resource.data.keys().hasAll(['userId', 'online', 'lastSeen', 'moveId']);
    }
    
    // Helper function to check if user is authenticated and has access to query moves
    function canQueryMoves() {
      return isAuthenticated();
    }
    
    // Helper function to validate presence data structure
    function isValidPresenceData() {
      return request.resource.data.keys().hasAll(['userId', 'online', 'lastSeen']) &&
             request.resource.data.userId == request.auth.uid &&
             (request.resource.data.online is bool) &&
             (request.resource.data.lastSeen is timestamp);
    }

    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Allow listing moves where user is a participant
    match /moves/{moveId} {
      // Allow listing moves where the user is a participant
      allow list: if canQueryMoves();
      
      // Only the initial creator can create the move, setting themselves as owner and participant
      allow create: if isAuthenticated() &&
                    request.resource.data.ownerId == request.auth.uid &&
                    (request.auth.uid in request.resource.data.participants) &&
                    request.resource.data.keys().hasAll(['moveCode', 'ownerId', 'participants', 'createdAt', 'updatedAt']);

      // Any move participant can read the main move details
      allow read: if isAuthenticated() && isMoveParticipant(moveId);

      // Allow updates under these conditions:
      allow update: if isAuthenticated() && (
        // 1. User is the owner
        request.auth.uid == resource.data.ownerId ||
        // 2. User is an existing participant updating their own status
        (resource.data.participants[request.auth.uid] == true && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt'])) ||
        // 3. New user joining by adding themselves to participants
        (!(request.auth.uid in resource.data.participants) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'updatedAt']) &&
         request.auth.uid in request.resource.data.participants)
      );

      // Only the owner can delete the move
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      
      // Presence subcollection rules
      match /presence/{userId} {
        // Users can read presence data for any user in the move
        allow read: if isAuthenticated() && isMoveParticipant(moveId);
        
        // Users can only write their own presence data
        allow write: if isAuthenticated() && 
                     isMoveParticipant(moveId) && 
                     userId == request.auth.uid &&
                     isValidPresenceData();
      }

      // Rules for the 'owners' subcollection (people/rooms who own boxes within this move)
      match /owners/{ownerId} {
        // Any move participant can read the list of owners/rooms
        allow read: if isAuthenticated() && isMoveParticipant(moveId);

        // Any move participant can create, update, or delete owners/rooms within this move
        allow write: if isAuthenticated() && isMoveParticipant(moveId);
      }

      // Rules for the 'boxes' subcollection
      match /boxes/{boxId} {
        // Any move participant can read box details
        allow read: if isAuthenticated() && isMoveParticipant(moveId);

        // Any move participant can create, update, or delete ANY box within this move
        allow write: if isAuthenticated() && isMoveParticipant(moveId);
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}